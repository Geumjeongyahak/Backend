<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="geumjeongyahak"/>
    <springProperty scope="context" name="activeProfile" source="SPRING_PROFILES_ACTIVE" defaultValue="default"/>
    <springProperty scope="context" name="rootLogLevel" source="LOG_LEVEL_ROOT" defaultValue="WARN"/>
    <springProperty scope="context" name="appLogLevel" source="LOG_LEVEL_APP" defaultValue="WARN"/>
    <springProperty scope="context" name="springLogLevel" source="LOG_LEVEL_SPRING" defaultValue="WARN"/>
    <springProperty scope="context" name="sqlLogLevel" source="LOG_LEVEL_SQL" defaultValue="WARN"/>
    <springProperty scope="context" name="logFileLevel" source="LOG_FILE_LEVEL" defaultValue="WARN"/>
    <springProperty scope="context" name="logFilePattern" source="LOG_FILE_PATTERN" defaultValue="./logs/app/application.%d{yyyy-MM-dd}.log"/>
    <springProperty scope="context" name="logFileMaxHistory" source="LOG_FILE_MAX_HISTORY" defaultValue="30"/>
    <springProperty scope="context" name="logFileTotalSizeCap" source="LOG_FILE_TOTAL_SIZE_CAP" defaultValue="1GB"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>false</includeContext>
            <customFields>{"service":"${appName}","profile":"${activeProfile}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <appender name="WARN_ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${logFileLevel}</level>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [trace_id=%X{trace_id:-} span_id=%X{span_id:-}] %logger{36} - %msg%n%ex</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${logFilePattern}</fileNamePattern>
            <maxHistory>${logFileMaxHistory}</maxHistory>
            <totalSizeCap>${logFileTotalSizeCap}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="${rootLogLevel}">
        <appender-ref ref="JSON_CONSOLE"/>
        <appender-ref ref="WARN_ERROR_FILE"/>
    </root>

    <logger name="geumjeongyahak" level="${appLogLevel}"/>
    <logger name="org.springframework" level="${springLogLevel}"/>
    <logger name="org.hibernate.SQL" level="${sqlLogLevel}"/>
</configuration>
