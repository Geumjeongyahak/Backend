SPRING_PROFILES_ACTIVE=prod
SPRING_PROFILES_ACTIVE_LOCAL=dev
APP_PORT=8080
MANAGEMENT_PORT=9090
DB_PORT=5432
NODE_EXPORTER_PORT=9100
CORS_ALLOWED_ORIGINS=https://app.example.com
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=WARN
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_SQL=WARN
APP_LOG_DIR=./logs/app
LOG_FILE_PATH=/app/logs/application.log
LOG_FILE_MAX_HISTORY=30
LOG_FILE_TOTAL_SIZE_CAP=1GB

JWT_SECRET=change-me
JWE_SECRET=change-me
JWT_ACCESS_EXP_SECONDS=1800
JWT_OAUTH2_TEMP_EXP_SECONDS=300
JWT_REFRESH_EXP_SECONDS=1209600

POSTGRES_DB=geumjeongyahak
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# In split GCE deployments, app connects to the DB server private IP or DNS name.
POSTGRES_HOST=10.0.0.20
POSTGRES_PORT=5432
DB_BIND_ADDRESS=0.0.0.0
POSTGRES_OPTIONS=
POSTGRES_VERSION=16-alpine
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false
FLYWAY_CONNECT_RETRIES=10
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_IDLE_TIMEOUT_MS=600000
DB_MAX_LIFETIME_MS=1800000
DB_LEAK_DETECTION_THRESHOLD_MS=0

ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password-1A!
ADMIN_NAME=관리자

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/api/v1/auth/google/callback
FRONTEND_REDIRECT_URI=https://app.example.com/auth/google/callback

GCP_PROJECT_ID=
GCP_DEV_BUCKET_NAME=
GCP_PROD_BUCKET_NAME=
GCP_ENCODED_CREDENTIALS=

APP_IMAGE=ghcr.io/geumjeongyahak/backend:latest

FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=geumjeongyahak
FIREBASE_CREDENTIALS_BASE64=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=geumjeongyahak
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_VAPID_KEY=
