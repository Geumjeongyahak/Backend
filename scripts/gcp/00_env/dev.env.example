# Copy this file to scripts/gcp/00_env/dev.env and edit values.
ENVIRONMENT=dev
PROJECT_ID=your-gcp-project-id
REGION=asia-northeast3
ZONE=asia-northeast3-a
NETWORK=default
SUBNET=default

APP_INSTANCE_NAME=gjlearn-dev-app
DB_INSTANCE_NAME=gjlearn-dev-db
APP_MACHINE_TYPE=e2-small
DB_MACHINE_TYPE=e2-micro
BOOT_DISK_SIZE_GB=10
BOOT_DISK_TYPE=pd-standard
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud

# App has a static external IP. DB keeps only a stable internal IP by default.
APP_STATIC_IP_NAME=gjlearn-dev-app-ip
DB_INTERNAL_IP_NAME=gjlearn-dev-db-ip
DB_INTERNAL_IP=
DB_EXTERNAL_IP_ENABLED=false

APP_NETWORK_TAG=gjlearn-dev-app
DB_NETWORK_TAG=gjlearn-dev-db

# Restrict these before running in a real project. CI/CD deploy uses SSH key access to the App VM.
# If using GitHub-hosted runners, allow the runner egress range or use a self-hosted runner/IAP alternative.
SSH_SOURCE_RANGES=0.0.0.0/0
HTTP_SOURCE_RANGES=0.0.0.0/0
HTTP_PORTS=tcp:80,tcp:443

APP_BOOT_DISK_NAME=gjlearn-dev-app-boot
DB_BOOT_DISK_NAME=gjlearn-dev-db-boot

APP_SERVICE_ACCOUNT_NAME=gjlearn-dev-app
STORAGE_BUCKET_NAME=gjlearn-dev-files
STORAGE_LOCATION=asia-northeast3
STORAGE_PUBLIC_READ=true
STORAGE_FOLDERS=profiles,editor,site-contents,documents/attachments,documents/purchase-items

# Lowest-cost dev option: set this true and skip creating a separate DB VM.
# The app VM will still be created; run the local/bundled compose there manually if needed.
SKIP_DB_INSTANCE=false

SERVER_APP_DIR=/home/min/app-dev
SERVER_DB_DIR=/home/min/db-dev
DEPLOY_OS_USER=min

API_DOMAIN=
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_REDIRECT_URI=http://localhost:3000/auth/google/callback
FRONTEND_BASE_URL=http://localhost:3000
ENABLE_CADDY=true

# MailerSend SMTP mail delivery. Keep disabled in dev unless you want real emails.
MAIL_ENABLED=false
MAIL_FALLBACK_TO_LOG=false
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=금정야학
MAIL_PASSWORD_RESET_PATH=/auth/reset-password
PASSWORD_RESET_EXPIRATION_MINUTES=15
MAIL_EMAIL_VERIFICATION_PATH=/auth/email-verification
EMAIL_VERIFICATION_EXPIRATION_MINUTES=15

# Optional MagicDNS names after `sudo tailscale up` on each server.
APP_TAILSCALE_HOST=gjlearn-dev-app.example.ts.net
DB_TAILSCALE_HOST=gjlearn-dev-db.example.ts.net

# Optional ACL tags advertised by install-app-service.sh / install-db-service.sh.
# Define tag owners first in the Tailscale policy file.
APP_TAILSCALE_TAGS=tag:gjlearn-dev-app,tag:gjlearn-app,tag:dev
DB_TAILSCALE_TAGS=tag:gjlearn-dev-db,tag:gjlearn-db,tag:dev

# Simple Tailscale node mode: keep GCE DNS and do not advertise subnet routes.
APP_TAILSCALE_ACCEPT_DNS=false
DB_TAILSCALE_ACCEPT_DNS=false

# GitHub Actions deploy secrets are configured in GitHub, not in this file:
# DEV_GCE_HOST, DEV_GCE_USER, DEV_GCE_SSH_KEY

# App VM ships local WARN/ERROR daily log files to Cloud Logging through the Ops Agent.
CLOUD_LOGGING_LOG_ID=gjlearn-dev-app
CLOUD_LOGGING_WARN_ERROR_METRIC_NAME=gjlearn_dev_app_warn_error_count
CLOUD_LOGGING_WARN_ERROR_POLICY_NAME=GJLearn-dev-app-WARN-ERROR-logs
# Optional comma-separated Monitoring notification channel resource names.
# ALERT_NOTIFICATION_CHANNELS=projects/PROJECT_ID/notificationChannels/CHANNEL_ID
