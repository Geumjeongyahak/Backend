# Copy this file to scripts/gcp/00_env/prod.env and edit values.
ENVIRONMENT=prod
PROJECT_ID=your-gcp-project-id
REGION=asia-northeast3
ZONE=asia-northeast3-a
NETWORK=default
SUBNET=default

APP_INSTANCE_NAME=gjlearn-prod-app
DB_INSTANCE_NAME=gjlearn-prod-db
APP_MACHINE_TYPE=e2-small
DB_MACHINE_TYPE=e2-micro
APP_BOOT_DISK_SIZE_GB=10
DB_BOOT_DISK_SIZE_GB=20
BOOT_DISK_TYPE=pd-standard
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud

# App has a static external IP. DB keeps only a stable internal IP by default.
APP_STATIC_IP_NAME=gjlearn-prod-app-ip
DB_INTERNAL_IP_NAME=gjlearn-prod-db-ip
DB_INTERNAL_IP=
DB_EXTERNAL_IP_ENABLED=false

APP_NETWORK_TAG=gjlearn-prod-app
DB_NETWORK_TAG=gjlearn-prod-db

# Use your admin/CI CIDR for SSH. CI/CD deploy uses SSH key access to the App VM.
# If using GitHub-hosted runners, allow the runner egress range or use a self-hosted runner/IAP alternative.
SSH_SOURCE_RANGES=YOUR_ADMIN_OR_GITHUB_RUNNER_IP/32
HTTP_SOURCE_RANGES=0.0.0.0/0
HTTP_PORTS=tcp:80,tcp:443

APP_BOOT_DISK_NAME=gjlearn-prod-app-boot
DB_BOOT_DISK_NAME=gjlearn-prod-db-boot

APP_SERVICE_ACCOUNT_NAME=gjlearn-prod-app
STORAGE_BUCKET_NAME=geumjeong-public-prod
STORAGE_LOCATION=asia-northeast3
STORAGE_PUBLIC_READ=true
STORAGE_FOLDERS=profiles,editor,site-contents,documents/attachments,documents/purchase-items

# Google Drive direct backend uploads. Share the Shared Drive/folders with the service account email.
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_MAKE_LINK_PUBLIC=true
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID_HANDOVER=
GOOGLE_DRIVE_FOLDER_ID_EXAM_MATERIALS=
GOOGLE_DRIVE_FOLDER_ID_DOCUMENT_FORMS=
GOOGLE_DRIVE_FOLDER_ID_MEETING_RECORDS=
GOOGLE_DRIVE_FOLDER_ID_BOARD=

SERVER_APP_DIR=/home/min/app-dev
SERVER_DB_DIR=/home/min/db-dev
DEPLOY_OS_USER=min

API_DOMAIN=api.example.com
FRONTEND_ORIGIN=https://app.example.com
FRONTEND_REDIRECT_URI=https://app.example.com/auth/google/callback
FRONTEND_BASE_URL=https://app.example.com
ENABLE_CADDY=true

# MailerSend SMTP mail delivery. Set MAIL_ENABLED=true after filling credentials.
MAIL_ENABLED=false
MAIL_FALLBACK_TO_LOG=false
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=금정야학
MAIL_PASSWORD_RESET_PATH=/auth/reset-password
PASSWORD_RESET_EXPIRATION_MINUTES=15
MAIL_EMAIL_VERIFICATION_PATH=/api/v1/auth/email-verification/confirm
EMAIL_VERIFICATION_EXPIRATION_MINUTES=15

# Optional MagicDNS name after `sudo tailscale up` on the App VM.
APP_TAILSCALE_HOST=gjlearn-prod-app.example.ts.net

# Optional ACL tags and subnet routes advertised by install-app-service.sh.
# Define tag owners first in the Tailscale policy file.
APP_TAILSCALE_TAGS=tag:gjlearn-prod-app,tag:gjlearn-app,tag:prod
APP_TAILSCALE_ROUTES=10.146.0.0/20

# App subnet-router mode: keep GCE DNS. DB stays private and is not a Tailscale node.
APP_TAILSCALE_ACCEPT_DNS=false

# GitHub Actions deploy secrets are configured in GitHub, not in this file:
# PROD_GCE_HOST, PROD_GCE_USER, PROD_GCE_SSH_KEY

# App VM ships local WARN/ERROR daily log files to Cloud Logging through the Ops Agent.
CLOUD_LOGGING_LOG_ID=gjlearn-prod-app
LOG_FILE_LEVEL=WARN
CLOUD_LOGGING_WARN_ERROR_METRIC_NAME=gjlearn_prod_app_warn_error_count
CLOUD_LOGGING_WARN_ERROR_POLICY_NAME=GJLearn-prod-app-WARN-ERROR-logs
# Optional comma-separated Monitoring notification channel resource names.
# ALERT_NOTIFICATION_CHANNELS=projects/PROJECT_ID/notificationChannels/CHANNEL_ID
