# Copy this file to scripts/gcp/env/prod.env and edit values.
ENVIRONMENT=prod
PROJECT_ID=your-gcp-project-id
REGION=asia-northeast3
ZONE=asia-northeast3-a
NETWORK=default
SUBNET=default

APP_INSTANCE_NAME=sonmoum-prod-app
DB_INSTANCE_NAME=sonmoum-prod-db
APP_MACHINE_TYPE=e2-small
DB_MACHINE_TYPE=e2-micro
BOOT_DISK_SIZE_GB=10
BOOT_DISK_TYPE=pd-standard
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud

# App has a static external IP. DB keeps only a stable internal IP by default.
APP_STATIC_IP_NAME=sonmoum-prod-app-ip
DB_INTERNAL_IP_NAME=sonmoum-prod-db-ip
DB_INTERNAL_IP=
DB_EXTERNAL_IP_ENABLED=false

APP_NETWORK_TAG=sonmoum-prod-app
DB_NETWORK_TAG=sonmoum-prod-db

# Use your admin/home/VPN CIDR, not 0.0.0.0/0.
SSH_SOURCE_RANGES=YOUR_ADMIN_OR_GITHUB_RUNNER_IP/32
HTTP_SOURCE_RANGES=0.0.0.0/0
HTTP_PORTS=tcp:8080
MONITORING_SOURCE_RANGES=YOUR_HOME_SERVER_VPN_OR_STATIC_IP/32

APP_BOOT_DISK_NAME=sonmoum-prod-app-boot
DB_BOOT_DISK_NAME=sonmoum-prod-db-boot

APP_SERVICE_ACCOUNT_NAME=sonmoum-prod-app
STORAGE_BUCKET_NAME=sonmoum-prod-files
STORAGE_LOCATION=asia-northeast3
STORAGE_PUBLIC_READ=false

SERVER_APP_DIR=/home/min/app-dev
SERVER_DB_DIR=/home/min/db-dev
DEPLOY_OS_USER=min

API_DOMAIN=api.example.com
FRONTEND_ORIGIN=https://app.example.com
FRONTEND_REDIRECT_URI=https://app.example.com/auth/google/callback
