# Copy this file to scripts/gcp/env/dev.env and edit values.
ENVIRONMENT=dev
PROJECT_ID=your-gcp-project-id
REGION=asia-northeast3
ZONE=asia-northeast3-a
NETWORK=default
SUBNET=default

APP_INSTANCE_NAME=sonmoum-dev-app
DB_INSTANCE_NAME=sonmoum-dev-db
APP_MACHINE_TYPE=e2-small
DB_MACHINE_TYPE=e2-micro
BOOT_DISK_SIZE_GB=10
BOOT_DISK_TYPE=pd-standard
IMAGE_FAMILY=ubuntu-2204-lts
IMAGE_PROJECT=ubuntu-os-cloud

# App has a static external IP. DB keeps only a stable internal IP by default.
APP_STATIC_IP_NAME=sonmoum-dev-app-ip
DB_INTERNAL_IP_NAME=sonmoum-dev-db-ip
DB_INTERNAL_IP=
DB_EXTERNAL_IP_ENABLED=false

APP_NETWORK_TAG=sonmoum-dev-app
DB_NETWORK_TAG=sonmoum-dev-db

# Restrict these before running in a real project.
SSH_SOURCE_RANGES=0.0.0.0/0
HTTP_SOURCE_RANGES=0.0.0.0/0
HTTP_PORTS=tcp:8080
MONITORING_SOURCE_RANGES=10.0.0.0/8

APP_BOOT_DISK_NAME=sonmoum-dev-app-boot
DB_BOOT_DISK_NAME=sonmoum-dev-db-boot

APP_SERVICE_ACCOUNT_NAME=sonmoum-dev-app
STORAGE_BUCKET_NAME=sonmoum-dev-files
STORAGE_LOCATION=asia-northeast3
STORAGE_PUBLIC_READ=false

# Lowest-cost dev option: set this true and skip creating a separate DB VM.
# The app VM will still be created; run the local/bundled compose there manually if needed.
SKIP_DB_INSTANCE=false

SERVER_APP_DIR=/home/min/app-dev
SERVER_DB_DIR=/home/min/db-dev
DEPLOY_OS_USER=min

API_DOMAIN=
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_REDIRECT_URI=http://localhost:3000/auth/google/callback
