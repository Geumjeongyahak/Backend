{
  "uid": "gjlearn-prod-app",
  "title": "GJLearn 프로덕션 APP",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "constant",
        "label": "Project",
        "query": "gjlearn",
        "current": {
          "text": "gjlearn",
          "value": "gjlearn"
        }
      },
      {
        "name": "env",
        "type": "constant",
        "label": "Environment",
        "query": "prod",
        "current": {
          "text": "prod",
          "value": "prod"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "App Node Up",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "CPU Used",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", mode=\"idle\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Memory Used",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - node_memory_MemAvailable_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"} / node_memory_MemTotal_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Disk Used",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(100 * (1 - node_filesystem_avail_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", fstype!~\"tmpfs|overlay\", mountpoint!~\"/run.*|/var/lib/.+\"} / node_filesystem_size_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", fstype!~\"tmpfs|overlay\", mountpoint!~\"/run.*|/var/lib/.+\"}))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Load Average",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 19,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_load1{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", mode!=\"idle\"}[5m]))",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Memory Breakdown",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_memory_MemTotal_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"} - node_memory_MemAvailable_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"}",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "node_memory_MemAvailable_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\"}",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "Disk Usage by Mount",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - node_filesystem_avail_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", fstype!~\"tmpfs|overlay\", mountpoint!~\"/run.*|/var/lib/.+\"} / node_filesystem_size_bytes{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", fstype!~\"tmpfs|overlay\", mountpoint!~\"/run.*|/var/lib/.+\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (device) (rate(node_network_receive_bytes_total{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", device!=\"lo\"}[5m]))",
          "legendFormat": "rx {{device}}"
        },
        {
          "refId": "B",
          "expr": "sum by (device) (rate(node_network_transmit_bytes_total{project=\"$project\", env=\"$env\", service=\"app\", role=\"node-exporter\", device!=\"lo\"}[5m]))",
          "legendFormat": "tx {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
