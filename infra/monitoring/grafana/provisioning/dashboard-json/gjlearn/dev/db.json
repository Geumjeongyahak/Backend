{
  "uid": "gjlearn-dev-db",
  "title": "GJLearn 개발 DB",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "constant",
        "label": "Project",
        "query": "gjlearn",
        "current": {
          "text": "gjlearn",
          "value": "gjlearn"
        }
      },
      {
        "name": "env",
        "type": "constant",
        "label": "Environment",
        "query": "dev",
        "current": {
          "text": "dev",
          "value": "dev"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Postgres Up",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_up{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 2,
      "title": "Connections Used",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(pg_stat_database_numbackends{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}) / max(pg_settings_max_connections{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Cache Hit",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(pg_stat_database_blks_hit{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}) / clamp_min(sum(pg_stat_database_blks_hit{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"} + pg_stat_database_blks_read{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Deadlocks 1h",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(pg_stat_database_deadlocks{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "DB Size",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 19,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_database_size_bytes{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "Connections by Database",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (pg_stat_database_numbackends{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Transaction Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}[5m]))",
          "legendFormat": "commit {{datname}}"
        },
        {
          "refId": "B",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}[5m]))",
          "legendFormat": "rollback {{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 8,
      "title": "Locks by Mode",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode) (pg_locks_count{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 9,
      "title": "Database Size by DB",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pg_database_size_bytes{project=\"$project\", env=\"$env\", service=\"postgres\", role=\"postgres-exporter\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {}
    }
  ]
}
