{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GJLearn Harness Task Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "files_changed",
    "verification",
    "blockers",
    "risks",
    "next_steps"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "exit_code", "evidence"],
        "properties": {
          "command": {"type": "string", "minLength": 1},
          "exit_code": {"type": "integer"},
          "evidence": {"type": "string"}
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "next_steps": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
